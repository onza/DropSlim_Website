{
  "name": "dropslim-website",
  "version": "1.0.0",
  "type": "module",
  "description": "Static marketing website for DropSlim app.",
  "productName": "DropSlim",
  "author": "Martin Farkas",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/onza/DropSlim_Website"
  },
  "homepage": "https://dropslim.app",
  "scripts": {
    "dev": "eleventy --serve",
    "build": "npm run verify-locales && npm run lint && npm run format:check && eleventy",
    "verify-locales": "node scripts/verify-locales.mjs",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"src/**/*.scss\"",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.scss\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-plugin-vite": "^8.0.0",
    "@eslint/js": "^10.0.1",
    "ajv": "^8.20.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "handlebars": "^4.7.9",
    "js-yaml": "^5.1.0",
    "marked": "^18.0.5",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "stylelint": "^17.13.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^17.0.0"
  }
}
