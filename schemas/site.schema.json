{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dropslim.app/schemas/site.schema.json",
  "title": "DropSlim locale site config",
  "type": "object",
  "additionalProperties": false,
  "required": ["seo", "strings", "install", "demo"],
  "properties": {
    "seo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["home", "legalNotice", "privacy"],
      "properties": {
        "home": { "$ref": "#/$defs/seoPage" },
        "legalNotice": { "$ref": "#/$defs/seoPage" },
        "privacy": { "$ref": "#/$defs/seoPage" }
      }
    },
    "strings": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "required": ["macos", "windows"],
      "properties": {
        "macos": { "$ref": "#/$defs/installPanel" },
        "windows": { "$ref": "#/$defs/installPanel" }
      }
    },
    "demo": {
      "type": "object",
      "required": ["rows"],
      "properties": {
        "queued": { "type": "string" },
        "compressing": { "type": "string" },
        "summary": { "type": "string" },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["filename", "result", "output"],
            "properties": {
              "filename": { "type": "string" },
              "result": { "type": "string" },
              "output": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "installPanel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["heading", "requirements", "steps"],
      "properties": {
        "heading": { "type": "string" },
        "requirements": { "type": "string" },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "note": { "type": "string" }
      }
    },
    "seoPage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description", "keywords"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "keywords": { "type": "string" }
      }
    }
  }
}
