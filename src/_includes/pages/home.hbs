<!doctype html>
<html lang="{{htmlLang}}">
  <head>
{{> head}}
  </head>
  <body>
{{> header}}
    <main id="main">
      <section class="section hero">
        <div class="hero-stage">
          <div class="hero-copy">
            <p class="hero-tag">{{home.heroTag}}</p>
            <h1>
              {{{home.heroTitleHtml}}}
            </h1>
            <div class="hero-rest">
              <div class="hero-sub">
                {{{home.heroSubHtml}}}
              </div>
              <div class="hero-cta">
                <a
                  href="{{release.url}}"
                  class="btn"
                  data-release-download
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path
                      d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
                    />
                  </svg>
                  {{t.download}}
                </a>
                <span class="hero-note">{{t.appleSilicon}}</span>
              </div>
            </div>
          </div>
          <div
            class="hero-demo app-window is-intro"
            aria-hidden="true"
            data-queued="{{demo.queued}}"
            data-demo-compressing="{{demo.compressing}}"
            data-demo-summary="{{demo.summary}}"
          >
            <div class="app-titlebar">
              <div class="app-traffic" aria-hidden="true">
                <span class="app-traffic__btn app-traffic__btn--close"></span>
                <span class="app-traffic__btn app-traffic__btn--minimize"></span>
                <span class="app-traffic__btn app-traffic__btn--zoom"></span>
              </div>
              <div class="app-titlebar__drag" aria-hidden="true"></div>
            </div>
            <div class="app-window__body">
              <div class="app-main">
                <section class="app-dragzone">
                  <p class="dragzone-status" hidden></p>
                  <h2>{{t.demoDropzone}}</h2>
                  <strong>{{t.demoFormats}}</strong>
                </section>
                <div class="results-panel">
                  <p class="batch-summary" hidden></p>
                  <section class="app-result">
                    {{#each demo.rows}}
                    <div class="demo-row queued" data-demo-row data-filename="{{filename}}">
                      <span class="demo-to" data-result="{{result}}">{{../t.waiting}}</span>
                      <span class="demo-path">{{output}}</span>
                    </div>
                    {{/each}}
                  </section>
                </div>
              </div>
              <footer class="app-footer">
                <div class="app-footer__group">
                  <span class="demo-cancel text-btn" hidden>{{t.cancel}}</span>
                  <span class="text-btn app-settings-btn">{{t.settingsHeading}}</span>
                </div>
              </footer>
            </div>
          </div>
        </div>
      </section>
      <section class="section pitch">
        <div class="pitch-stat">
          <span class="stat-value">
            <span class="stat-num" data-count="80">0</span><span class="stat-unit">%</span>
          </span>
          <p>{{home.lessVolume}}</p>
        </div>
        <div class="pitch-copy">
          {{{home.pitchHtml}}}
        </div>
      </section>
      <section class="section list-section">
        <h2>{{home.whyHeading}}</h2>
        <div class="tile-grid">
          <div
            class="compare-block glass-panel fat"
            role="group"
            aria-label="{{home.compareBeforeAria}}"
          >
            <span class="compare-label">{{home.before}}</span>
            <span class="compare-value">12,4&nbsp;MB</span>
            <span class="compare-desc">{{home.compareBeforeDesc}}</span>
          </div>
          <div
            class="compare-block glass-panel slim"
            role="group"
            aria-label="{{home.compareAfterAria}}"
          >
            <span class="compare-label">{{home.after}}</span>
            <span class="compare-value">2,1&nbsp;MB</span>
            <span class="compare-desc">{{home.compareAfterDesc}}</span>
          </div>
          <ul class="feature-list">
            {{#each home.features}}
            <li class="feature-tile glass-panel">
              <span class="li-num" aria-hidden="true">{{num}}</span>
              <div>
                <h3>{{title}}</h3>
                {{#if html}}
                <p>{{{body}}}</p>
                {{else}}
                <p>{{body}}</p>
                {{/if}}
              </div>
            </li>
            {{/each}}
          </ul>
        </div>
      </section>
      <section id="download" class="section download">
        <h2>{{t.getIt}}</h2>
        <p>{{t.downloadIntro}}</p>
        <a
          href="{{release.url}}"
          class="btn btn-large"
          data-release-download
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
            />
          </svg>
          {{t.downloadForMacos}}
        </a>
        <p class="download-version">
          {{withReleaseVersion t.downloadVersion release.version}}
        </p>
      </section>
    </main>
{{> footer}}
{{> scripts}}
  </body>
</html>
